<Window x:Class="LibVLCSharp.WPF.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="LibVLC4Sharp WPF Sample (airspace-free)"
        Width="960" Height="600" Background="Black">
    <Grid>
        <!-- The video surface -->
        <vlc:VideoView x:Name="Video" Engine="D3D11" />

        <!-- Proof that the airspace problem is gone: a semi-transparent WPF overlay
             with opacity + a clickable button, composited ON TOP of the playing video. -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16"
                Background="#99000000" CornerRadius="8" Padding="14">
            <StackPanel>
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold"
                           Text="WPF overlay over video ✔ (no airspace)" />
                <TextBlock Foreground="#CCFFFFFF" FontSize="12" Margin="0,4,0,8"
                           Text="Semi-transparent, with a real WPF button on top." />
                <Button Content="Click me" Width="100" HorizontalAlignment="Left"
                        Click="OnOverlayClick" />
            </StackPanel>
        </Border>

        <!-- Transport bar -->
        <Grid VerticalAlignment="Bottom" Background="#CC202020">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="Mrl" Grid.Column="0" Margin="8" VerticalContentAlignment="Center"
                     Text="" ToolTip="A file path or a URL (http://, rtsp://, ...)" />
            <Button x:Name="OpenButton" Grid.Column="1" Content="Open file…" Margin="0,8,4,8" Padding="10,4" Click="OnOpenFile" IsEnabled="False" />
            <Button x:Name="PlayButton" Grid.Column="2" Content="Play" Margin="0,8,4,8" Padding="14,4" Click="OnPlay" IsEnabled="False" />
            <Button Grid.Column="3" Content="Stop" Margin="0,8,8,8" Padding="14,4" Click="OnStop" />
        </Grid>
    </Grid>
</Window>
