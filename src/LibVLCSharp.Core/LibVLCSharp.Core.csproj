<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;netstandard2.1;net8.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <RootNamespace>LibVLCSharp.Core</RootNamespace>
    <AssemblyName>LibVLCSharp.Core</AssemblyName>
    <PackageId>LibVLC4Sharp.Core</PackageId>
    <Description>[unofficial] LibVLC 4.x for .NET: auto-generated snake_case P/Invoke bindings plus a managed object-oriented API (LibVLC/Media/MediaPlayer/...). One package; pick the native linking strategy at startup via the Core class (default search / explicit path / static).</Description>
    <NoWarn>$(NoWarn);CS8981</NoWarn>
    <Platforms>AnyCPU;x64</Platforms>
  </PropertyGroup>

  <ItemGroup>
	  <PackageReference Include="System.Memory" Version="[4.5.5,)" Condition="'$(TargetFramework)' == 'netstandard2.0'" />
	  <PackageReference Include="System.Runtime.CompilerServices.Unsafe" Version="[6.0.0,)" Condition="'$(TargetFramework)' == 'netstandard2.0' Or '$(TargetFramework)' == 'netstandard2.1'" />
  </ItemGroup>
 
  <ItemGroup>
    <ProjectReference Include="..\LibVLCSharp.Core.Generator\LibVLCSharp.Core.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>
 
  <ItemGroup>
    <Folder Include="Generated\" />
  </ItemGroup>

</Project>
