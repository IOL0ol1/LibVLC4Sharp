--additional
-m64

--config
generate-aggressive-inlining 
generate-macro-bindings 
exclude-funcs-with-body 
compatible-codegen
single-file
#unix-types
#multi-file
#latest-codegen
#default-codegen
#generate-doc-includes
#generate-disable-runtime-marshalling
#generate-helper-types

--language
c

--file
./vlc/vlc.h

--file-directory
./.vlc/include

--include-directory
./.vlc/include
./.vlc/include/vlc

--traverse
./.vlc/include/vlc/libvlc.h
./.vlc/include/vlc/libvlc_dialog.h
./.vlc/include/vlc/libvlc_events.h
./.vlc/include/vlc/libvlc_media.h
./.vlc/include/vlc/libvlc_media_discoverer.h
./.vlc/include/vlc/libvlc_media_list.h
./.vlc/include/vlc/libvlc_media_list_player.h
./.vlc/include/vlc/libvlc_media_player.h
./.vlc/include/vlc/libvlc_media_track.h
./.vlc/include/vlc/libvlc_picture.h
./.vlc/include/vlc/libvlc_renderer_discoverer.h
./.vlc/include/vlc/libvlc_version.h
./.vlc/include/vlc/libvlc_video.h

--libraryPath
libvlc

--methodClassName
libvlc

--namespace
LibVLCSharp.Core.Interop

--output
../src/LibVLCSharp.Core/Generated/LibVLC.Interop.g.cs

--exclude
VLC_FORWARD_DECLARE_OBJECT
LIBVLC_VERSION
libvlc_role_Last
libvlc_printerr

--with-callconv
*=Cdecl

--with-attribute
libvlc_media_parse_flag_t=Flags

--remap
vlc_log_t=libvlc_log_t
libvlc_media_player_role=libvlc_media_player_role_t
void*=@IntPtr
FILE *=@IntPtr
char=byte
